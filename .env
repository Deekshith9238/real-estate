# Database connection string (e.g., PostgreSQL connection URL)
# Example: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=postgresql://user:password@db:5432/nripropservices

# Server port (defaults to 5000 in Vite, but 5173 is also used in some places)
PORT=5000

# Node environment (development, production)
NODE_ENV=development

# --- Optional / OIDC Auth Settings ---
# If you are using Replit Auth (OIDC), provide these:
# REPL_ID=
# SESSION_SECRET=your_super_secret_session_key
# ISSUER_URL=https://replit.com/oidc
